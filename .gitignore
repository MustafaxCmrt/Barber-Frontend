# =====================================================================
# Barbeyond Frontend — .gitignore
# Vite + React + TypeScript + Tailwind projesi için kapsamlı ignore listesi
# =====================================================================


# ---------------------------------------------------------------------
# Bağımlılıklar (node_modules)
# ---------------------------------------------------------------------
node_modules/
jspm_packages/
bower_components/
.pnp
.pnp.js
.pnp.cjs
.pnp.loader.mjs
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.yarn/.pnp.*
.pnpm-store/


# ---------------------------------------------------------------------
# Build çıktıları (Vite / Rollup / TS)
# ---------------------------------------------------------------------
dist/
dist-ssr/
build/
out/
.vite/
.rollup.cache/
.turbo/
.next/
.nuxt/
.cache/
.parcel-cache/
.svelte-kit/
.docusaurus/
.serverless/
.fusebox/
.dynamodb/
.tern-port

# TypeScript build info
*.tsbuildinfo
tsconfig.tsbuildinfo


# ---------------------------------------------------------------------
# Environment dosyaları (KRİTİK — secret'lar için)
# ---------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.*.local

# .env.example commit'lenmeli (template), istisna olarak tut
!.env.example
!.env.sample
!.env.template


# ---------------------------------------------------------------------
# Loglar
# ---------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
firebase-debug.log
firebase-debug.*.log


